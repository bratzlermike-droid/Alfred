# ── Alfred AI Assistant — environment template ──
# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored and must never be committed.

# Shared auth token between server and clients (pick any strong random string)
ALFRED_AUTH_TOKEN=change-me-to-a-long-random-string

# URL where the FastAPI server is reachable (clients use this)
ALFRED_SERVER_URL=http://localhost:8000

# LLM — Groq (free tier) is the primary provider; Ollama is the local fallback
GROQ_API_KEY=your_groq_api_key_here

# Premium desktop TTS (optional — falls back to local Kokoro voice if unset)
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Email features (use a Gmail App Password, not your account password)
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here
