<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<title>A L F R E D</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{--cyan:#00f0ff;--cyan-dim:rgba(0,240,255,.15);--dark:#060a10;--panel:rgba(6,16,28,.85);
--text:#c8dce8;--text-dim:#5a7a8a;--danger:#ff3050;--success:#00ff88}
html,body{height:100%;background:var(--dark);color:var(--text);font-family:'Rajdhani',sans-serif;overflow:hidden}
body::before{content:'';position:fixed;inset:0;background:radial-gradient(ellipse at 50% 0%,rgba(0,100,255,.08) 0%,transparent 60%);pointer-events:none;z-index:0}

.app{display:flex;flex-direction:column;height:100vh;position:relative;z-index:1}

.header{padding:12px 20px;display:flex;align-items:center;justify-content:space-between;
border-bottom:1px solid rgba(0,240,255,.15);background:linear-gradient(180deg,rgba(0,20,40,.6),transparent)}
.logo{font-family:'Orbitron',sans-serif;font-weight:900;font-size:20px;letter-spacing:6px;color:var(--cyan);
text-shadow:0 0 20px rgba(0,240,255,.4)}
.status{display:flex;align-items:center;gap:6px;font-size:12px;letter-spacing:2px}
.status-dot{width:8px;height:8px;border-radius:50%;background:var(--success);box-shadow:0 0 8px var(--success);animation:pulse 2s ease infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}

.quick-btns{display:flex;gap:6px;padding:8px 16px;overflow-x:auto;border-bottom:1px solid rgba(0,240,255,.08)}
.qbtn{background:rgba(0,240,255,.06);border:1px solid rgba(0,240,255,.15);border-radius:16px;
padding:6px 14px;color:var(--cyan);font-size:12px;font-family:'Rajdhani',sans-serif;font-weight:500;
cursor:pointer;white-space:nowrap;transition:all .2s}
.qbtn:hover{background:rgba(0,240,255,.12);border-color:rgba(0,240,255,.3)}
.qbtn:active{transform:scale(.95)}

.messages{flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:12px;
scrollbar-width:thin;scrollbar-color:rgba(0,240,255,.2) transparent}
.messages::-webkit-scrollbar{width:4px}
.messages::-webkit-scrollbar-thumb{background:rgba(0,240,255,.3);border-radius:2px}

.msg{max-width:85%;animation:fadeIn .3s ease}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
.msg-user{align-self:flex-end;background:linear-gradient(135deg,rgba(0,100,255,.2),rgba(0,60,120,.15));
border:1px solid rgba(0,100,255,.3);border-radius:14px 14px 4px 14px;padding:10px 14px;font-size:14px}
.msg-alfred{align-self:flex-start;background:linear-gradient(135deg,rgba(0,240,255,.08),rgba(0,240,255,.03));
border:1px solid rgba(0,240,255,.15);border-radius:14px 14px 14px 4px;padding:10px 14px;font-size:14px;line-height:1.5}
.msg-alfred .label{font-family:'Orbitron',sans-serif;font-size:9px;letter-spacing:3px;color:var(--cyan);margin-bottom:4px}
.msg-user .label{font-size:9px;letter-spacing:3px;color:rgba(0,100,255,.7);margin-bottom:4px;text-align:right}
.msg-system{align-self:center;color:var(--text-dim);font-size:12px;padding:6px 12px;
border:1px solid rgba(255,255,255,.05);border-radius:16px;background:rgba(255,255,255,.02)}

.thinking{display:flex;align-items:center;gap:6px;padding:8px}
.thinking-dot{width:5px;height:5px;border-radius:50%;background:var(--cyan);animation:think .8s ease infinite}
.thinking-dot:nth-child(2){animation-delay:.15s}
.thinking-dot:nth-child(3){animation-delay:.3s}
@keyframes think{0%,100%{opacity:.2;transform:scale(.8)}50%{opacity:1;transform:scale(1.2)}}

.input-area{padding:12px 16px;border-top:1px solid rgba(0,240,255,.15);
background:linear-gradient(0deg,rgba(0,20,40,.6),transparent)}
.input-row{display:flex;gap:8px;align-items:center}
.text-input{flex:1;background:rgba(0,240,255,.05);border:1px solid rgba(0,240,255,.2);
border-radius:22px;padding:10px 18px;color:var(--text);font-size:14px;
font-family:'Rajdhani',sans-serif;outline:none;transition:border-color .2s}
.text-input:focus{border-color:var(--cyan);box-shadow:0 0 12px rgba(0,240,255,.12)}
.text-input::placeholder{color:var(--text-dim)}

.btn{width:42px;height:42px;border-radius:50%;border:1px solid rgba(0,240,255,.3);
background:rgba(0,240,255,.08);color:var(--cyan);font-size:18px;
cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;flex-shrink:0}
.btn:hover{background:rgba(0,240,255,.15)}
.btn:active{transform:scale(.95)}
.btn-mic.recording{border-color:var(--danger);background:rgba(255,48,80,.15);color:var(--danger);
animation:rec-pulse 1s ease infinite}
@keyframes rec-pulse{0%,100%{box-shadow:0 0 0 0 rgba(255,48,80,.3)}50%{box-shadow:0 0 0 10px rgba(255,48,80,0)}}

@media(max-width:600px){
.header{padding:10px 14px}.logo{font-size:16px;letter-spacing:4px}
.messages{padding:10px 12px}.msg{max-width:92%}.qbtn{font-size:11px;padding:5px 10px}
}
</style>
</head>
<body>
<div class="app">
  <div class="header">
    <div class="logo">ALFRED</div>
    <div class="status">
      <span class="status-dot" id="statusDot"></span>
      <span id="statusText">CONNECTING</span>
    </div>
  </div>

  <div class="quick-btns">
    <div class="qbtn" onclick="send('Brief me')">Briefing</div>
    <div class="qbtn" onclick="send('Whats the weather')">Weather</div>
    <div class="qbtn" onclick="send('My reminders')">Reminders</div>
    <div class="qbtn" onclick="send('Monthly spending')">Spending</div>
    <div class="qbtn" onclick="send('Check watchlist')">Stocks</div>
    <div class="qbtn" onclick="send('Whats the latest news')">News</div>
  </div>

  <div class="messages" id="messages">
    <div class="msg msg-system">Alfred — Personal AI Assistant</div>
  </div>

  <div class="input-area">
    <div class="input-row">
      <button class="btn btn-mic" id="micBtn" onclick="toggleRecord()" title="Push to talk">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
      </button>
      <input type="text" class="text-input" id="textInput" placeholder="Talk to Alfred..." onkeydown="if(event.key==='Enter')sendText()">
      <button class="btn" onclick="sendText()" title="Send">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
      </button>
    </div>
  </div>
</div>

<script>
const SERVER = window.location.origin;
const TOKEN = 'Bearer REPLACE_WITH_YOUR_TOKEN';
const messagesEl = document.getElementById('messages');
const textInput = document.getElementById('textInput');
const micBtn = document.getElementById('micBtn');

let history = [];
let recording = false;
let mediaRecorder = null;
let audioChunks = [];

async function checkStatus() {
  try {
    const r = await fetch(SERVER + '/status');
    const d = await r.json();
    document.getElementById('statusDot').style.background = 'var(--success)';
    document.getElementById('statusText').textContent = 'ONLINE';
  } catch {
    document.getElementById('statusDot').style.background = 'var(--danger)';
    document.getElementById('statusText').textContent = 'OFFLINE';
  }
}

function addMsg(text, type) {
  const div = document.createElement('div');
  div.className = 'msg msg-' + type;
  if (type === 'alfred') {
    div.innerHTML = '<div class="label">ALFRED</div>' + esc(text);
  } else if (type === 'user') {
    div.innerHTML = '<div class="label">YOU</div>' + esc(text);
  } else {
    div.textContent = text;
  }
  messagesEl.appendChild(div);
  messagesEl.scrollTop = messagesEl.scrollHeight;
}

function esc(t) { const d = document.createElement('div'); d.textContent = t; return d.innerHTML; }

function showThinking() {
  const div = document.createElement('div');
  div.className = 'msg msg-alfred'; div.id = 'thinking';
  div.innerHTML = '<div class="label">ALFRED</div><div class="thinking"><div class="thinking-dot"></div><div class="thinking-dot"></div><div class="thinking-dot"></div></div>';
  messagesEl.appendChild(div);
  messagesEl.scrollTop = messagesEl.scrollHeight;
}
function removeThinking() { const el = document.getElementById('thinking'); if (el) el.remove(); }

function send(text) {
  textInput.value = '';
  addMsg(text, 'user');
  showThinking();
  fetch(SERVER + '/chat', {
    method: 'POST',
    headers: { 'Authorization': TOKEN, 'Content-Type': 'application/json' },
    body: JSON.stringify({ message: text, history: history.slice(-6) })
  }).then(r => r.json()).then(d => {
    removeThinking();
    addMsg(d.reply, 'alfred');
    history.push({ role: 'user', content: text });
    history.push({ role: 'assistant', content: d.reply });
    playTTS(d.reply);
  }).catch(e => {
    removeThinking();
    addMsg('Connection error', 'system');
  });
}

function sendText() {
  const t = textInput.value.trim();
  if (t) send(t);
}

let ttsVoice = null;
function loadVoice() {
  const voices = speechSynthesis.getVoices();
  // Prefer British English male voice
  ttsVoice = voices.find(v => v.lang === 'en-GB' && v.name.toLowerCase().includes('male'))
    || voices.find(v => v.lang === 'en-GB')
    || voices.find(v => v.lang.startsWith('en'))
    || voices[0];
}
speechSynthesis.onvoiceschanged = loadVoice;
loadVoice();

function playTTS(text) {
  if (!('speechSynthesis' in window)) return;
  speechSynthesis.cancel();
  const utt = new SpeechSynthesisUtterance(text);
  if (ttsVoice) utt.voice = ttsVoice;
  utt.rate = 1.0;
  utt.pitch = 0.9;
  speechSynthesis.speak(utt);
}

async function toggleRecord() {
  if (!recording) {
    try {
      const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
      mediaRecorder = new MediaRecorder(stream, { mimeType: 'audio/webm' });
      audioChunks = [];
      mediaRecorder.ondataavailable = e => audioChunks.push(e.data);
      mediaRecorder.onstop = async () => {
        stream.getTracks().forEach(t => t.stop());
        const blob = new Blob(audioChunks, { type: 'audio/webm' });
        await sendVoice(blob);
      };
      mediaRecorder.start();
      recording = true;
      micBtn.classList.add('recording');
    } catch { addMsg('Microphone access denied', 'system'); }
  } else {
    recording = false;
    micBtn.classList.remove('recording');
    if (mediaRecorder && mediaRecorder.state !== 'inactive') mediaRecorder.stop();
  }
}

async function sendVoice(blob) {
  showThinking();
  try {
    const fd = new FormData();
    fd.append('audio', blob, 'audio.webm');
    const tr = await fetch(SERVER + '/transcribe', { method: 'POST', headers: { 'Authorization': TOKEN }, body: fd });
    const td = await tr.json();
    if (!td.text) { removeThinking(); addMsg('Could not hear you', 'system'); return; }
    addMsg(td.text, 'user');
    const cr = await fetch(SERVER + '/chat', {
      method: 'POST',
      headers: { 'Authorization': TOKEN, 'Content-Type': 'application/json' },
      body: JSON.stringify({ message: td.text, history: history.slice(-6) })
    });
    const cd = await cr.json();
    removeThinking();
    addMsg(cd.reply, 'alfred');
    history.push({ role: 'user', content: td.text });
    history.push({ role: 'assistant', content: cd.reply });
    playTTS(cd.reply);
  } catch (e) { removeThinking(); addMsg('Error: ' + e.message, 'system'); }
}

checkStatus();
setInterval(checkStatus, 30000);
textInput.focus();
</script>
</body>
</html>
