"""
Alfred's HUD Overlay
Always-on-top transparent panel showing live stats.
"""
import tkinter as tk
import threading
import time
import datetime
import psutil


class HUDOverlay:
    """Transparent always-on-top HUD panel."""

    def __init__(self):
        self.root = tk.Toplevel()
        self.root.title("Alfred HUD")
        self.root.overrideredirect(True)  # No window borders
        self.root.attributes('-topmost', True)  # Always on top
        self.root.attributes('-alpha', 0.85)  # Slight transparency
        self.root.configure(bg='#0a0e14')

        # Position: top-right corner
        screen_w = self.root.winfo_screenwidth()
        self.hud_width = 220
        self.hud_height = 160
        x = screen_w - self.hud_width - 10
        y = 10
        self.root.geometry(str(self.hud_width) + "x" + str(self.hud_height) + "+" + str(x) + "+" + str(y))

        # Make it click-through-able by allowing drag
        self._drag_x = 0
        self._drag_y = 0
        self.root.bind('<Button-1>', self._start_drag)
        self.root.bind('<B1-Motion>', self._do_drag)
        self.root.bind('<Double-Button-1>', self.toggle_visibility)

        self._build()
        self.visible = True
        self._update_loop()

    def _build(self):
        bg = '#0a0e14'
        border_color = '#0a3040'
        cyan = '#00d0e0'
        text = '#8ab0c0'
        dim = '#3a5a6a'

        # Outer border
        frame = tk.Frame(self.root, bg=border_color, padx=1, pady=1)
        frame.pack(fill='both', expand=True)

        inner = tk.Frame(frame, bg=bg)
        inner.pack(fill='both', expand=True, padx=0, pady=0)

        # Title
        tk.Label(inner, text="A L F R E D", font=("Consolas", 8, "bold"),
                 fg=cyan, bg=bg).pack(pady=(4, 2))

        # Clock
        self.clock_label = tk.Label(inner, text="", font=("Consolas", 16, "bold"),
                                     fg=cyan, bg=bg)
        self.clock_label.pack()

        # Date
        self.date_label = tk.Label(inner, text="", font=("Consolas", 8),
                                    fg=dim, bg=bg)
        self.date_label.pack()

        # Stats frame
        stats = tk.Frame(inner, bg=bg)
        stats.pack(fill='x', padx=10, pady=(6, 2))

        # CPU
        tk.Label(stats, text="CPU", font=("Consolas", 8), fg=dim, bg=bg).grid(row=0, column=0, sticky='w')
        self.cpu_label = tk.Label(stats, text="—", font=("Consolas", 8, "bold"), fg=text, bg=bg)
        self.cpu_label.grid(row=0, column=1, sticky='e', padx=(10, 0))

        # RAM
        tk.Label(stats, text="RAM", font=("Consolas", 8), fg=dim, bg=bg).grid(row=1, column=0, sticky='w')
        self.ram_label = tk.Label(stats, text="—", font=("Consolas", 8, "bold"), fg=text, bg=bg)
        self.ram_label.grid(row=1, column=1, sticky='e', padx=(10, 0))

        # Disk
        tk.Label(stats, text="DSK", font=("Consolas", 8), fg=dim, bg=bg).grid(row=2, column=0, sticky='w')
        self.disk_label = tk.Label(stats, text="—", font=("Consolas", 8, "bold"), fg=text, bg=bg)
        self.disk_label.grid(row=2, column=1, sticky='e', padx=(10, 0))

        stats.columnconfigure(1, weight=1)

        # Weather line
        self.weather_label = tk.Label(inner, text="", font=("Consolas", 7),
                                       fg=dim, bg=bg)
        self.weather_label.pack(pady=(4, 4))

    def _start_drag(self, event):
        self._drag_x = event.x
        self._drag_y = event.y

    def _do_drag(self, event):
        x = self.root.winfo_x() + event.x - self._drag_x
        y = self.root.winfo_y() + event.y - self._drag_y
        self.root.geometry("+" + str(x) + "+" + str(y))

    def toggle_visibility(self, event=None):
        if self.visible:
            self.root.withdraw()
            self.visible = False
        else:
            self.root.deiconify()
            self.visible = True

    def show(self):
        self.root.deiconify()
        self.visible = True

    def hide(self):
        self.root.withdraw()
        self.visible = False

    def _update_loop(self):
        """Update HUD stats every 2 seconds."""
        try:
            now = datetime.datetime.now()
            self.clock_label.config(text=now.strftime("%I:%M %p"))
            self.date_label.config(text=now.strftime("%A, %b %d"))

            cpu = psutil.cpu_percent(interval=0)
            ram = psutil.virtual_memory().percent
            disk = psutil.disk_usage('C:\\').percent

            # Color code based on usage
            self.cpu_label.config(text=str(cpu) + "%",
                fg='#ff3050' if cpu > 90 else '#ffaa00' if cpu > 70 else '#8ab0c0')
            self.ram_label.config(text=str(ram) + "%",
                fg='#ff3050' if ram > 90 else '#ffaa00' if ram > 70 else '#8ab0c0')
            self.disk_label.config(text=str(disk) + "%",
                fg='#ff3050' if disk > 90 else '#ffaa00' if disk > 80 else '#8ab0c0')

        except Exception as e:
            print("HUD update error:", e)

        self.root.after(2000, self._update_loop)

    def update_weather(self, weather_text):
        """Update the weather display."""
        try:
            self.weather_label.config(text=weather_text[:40])
        except:
            pass
